<?xml version="1.0" encoding="EUC-KR"?>
<SABANG_ORDER_LIST>
	<HEADER>
        <SEND_COMPAYNY_ID><%= agentUserId %></SEND_COMPAYNY_ID>
        <SEND_AUTH_KEY><%= agentApiKey %></SEND_AUTH_KEY>
        <SEND_DATE><%= sendDate %></SEND_DATE>
    </HEADER>
	<DATA>
		<CLM_ST_DATE><%= startDate %></CLM_ST_DATE>
		<CLM_ED_DATE><%= endDate %></CLM_ED_DATE>
		<%if(clmField != null && !clmField.isEmpty()) { %>
        <CLM_FIELD><![CDATA[<%=clmField%>]]></CLM_FIELD>
        <%} else { %>
        	<CLM_FIELD><![CDATA[IDX|ORDER_ID|MALL_ID|ORDER_STATUS|CLAME_INS_DATE|CLAME_REG_DATE|CLAME_STATUS_GUBUN|CL_IDX|CLAME_CONTENT]]></CLM_FIELD>
        <%} %>
	</DATA>
</SABANG_ORDER_LIST>
